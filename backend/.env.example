# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/threadsense

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_TOKEN=

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Supabase (backend uses non-VITE prefix, but accepts both)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# App
APP_ENV=dev
DEBUG=false
THREADSENSE_ADMIN_KEY=change-me-in-production
